<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>Mes listes de films</h1>
  <%= link_to "+ Nouvelle liste", new_list_path, class: "btn btn-primary" %>
</div>

<div class="row">
  <% @lists.each do |list| %>
    <div class="col-md-4 mb-3">
      <div class="card h-100">
        <% if list.cover.attached? %>
          <%= image_tag list.cover, class: "card-img-top", style: "height: 180px; object-fit: cover;" %>
        <% end %>
        <div class="card-body">
          <h5 class="card-title"><%= list.name %></h5>
          <p class="card-text text-muted"><%= pluralize(list.movies.count, "film") %></p>
            <%= link_to "Voir la liste", list_path(list), class: "btn btn-outline-primary" %>
        </div>
      </div>
    </div>
  <% end %>
</div>
