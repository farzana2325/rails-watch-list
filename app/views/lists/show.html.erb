<div class="d-flex justify-content-between align-items-center mb-4">
  <h1><%= @list.name %></h1>
  <%= link_to "+ Ajouter un film", new_list_bookmark_path(@list), class: "btn btn-primary" %>
</div>

<% if @list.cover.attached? %>
  <%= image_tag @list.cover, class: "img-fluid rounded mb-4", style: "max-height: 400px; width: 100%; object-fit: cover;" %>
<% end %>

<div class="row">
  <% @list.bookmarks.each do |bookmark| %>
    <div class="col-md-3 mb-4">
      <div class="card h-100">
        <%= image_tag bookmark.movie.poster_url, class: "card-img-top", alt: bookmark.movie.title %>
        <div class="card-body">
          <h5 class="card-title"><%= bookmark.movie.title %></h5>
          <p class="card-text"><span class="badge bg-warning text-dark">⭐ <%= bookmark.movie.rating %></span></p>
          <p class="card-text text-muted small"><%= bookmark.comment %></p>
        </div>
        <div class="card-footer bg-white border-0">
          <%= button_to "Supprimer", bookmark, method: :delete, class: "btn btn-outline-danger btn-sm w-100" %>
        </div>
      </div>
    </div>
  <% end %>
</div>
